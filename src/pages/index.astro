---
import '@fontsource/poppins';
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta content="rhamburg.com" name="description"/>

		<meta property="og:title" content="">
		<meta property="og:type" content="">
		<meta property="og:url" content="">
		<meta property="og:image" content="">

		<link rel="icon" href="/favicon.ico" sizes="any">
		<link rel="icon" href="/icon.svg" type="image/svg+xml">
		<link rel="apple-touch-icon" href="icon.png">

		<link rel="manifest" href="/site.webmanifest">
		<meta name="theme-color" content="#272930">

		<title>(rh)amburg.com | creative.technology</title>
	</head>
	<body>
		<div id="main">
            <div id="content">
                <section class="logo">
                    <img class="rh" src="/logo.svg" alt="rhamburg logo" />
                    <header>
                        <h1>rich<em>hamburg</em></h1>
                        <h2><em>rhamburg</em>.com</h2>
                    </header>
                </section>
            </div>
        </div>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}
	html,
	body {
		height: 100%;
		margin: 0;
	}

	body {
		background-color: #32353e;
	}

	#main {
		bottom: 0;
		border-right: #3e424c 1px solid;
		border-left: black 1px solid;
		height: 100%;
		margin: 0 auto;
		min-width: 150px;
		width: 25%;
	}

	#content {
		background-color: #272930;
		box-sizing: border-box;
		height: 100%;
		position: relative;
		width: 100%;
	}

	.logo {
		color: #ffffff;
		display: inline-block;
		font-family: "Poppins", sans-serif;
		font-size: 7px;
		left: 50%;
		margin-left: -15.25em;
		margin-top: -3.125em;
		position: absolute;
		text-align: center;
		top: 50%;
		width: 30.5em;
	}
	.logo .rh {
		float: left;
		height: auto;
		margin: 0 auto;
		position: relative;
		width: 8.65em;
		fill: #bada55;
	}
	@media screen and (max-width: 1024px) {
		.logo .rh {
			display: block;
			float: none;
		}
	}
	.logo header {
		font-size: 1em;
		font-weight: 100;
		padding: 2em 0 2em 10em;
		text-align: left;
	}
	.logo header h1 {
		font-size: 2.5em;
		font-weight: 200;
		margin: 0;
	}
	.logo header h1 em {
		font-style: normal;
		font-weight: 500;
	}
	.logo header h2 {
		color: #ee6926;
		font-size: 1.5em;
		font-weight: 500;
		line-height: 1.4em;
		margin: 0;
	}
	.logo header h2 em {
		color: #ffffff;
		font-style: normal;
	}
	@media screen and (max-width: 1024px) {
		.logo header {
			display: inline-block;
			padding-left: 0;
			text-align: center;
		}
	}
	</style>
